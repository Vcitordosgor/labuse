# LA BUSE — configuration d'environnement (copier en .env)

# --- Base PostGIS (socle non négociable : PostgreSQL 15+ / PostGIS 3+) ---
LABUSE_DATABASE_URL=postgresql+psycopg://labuse:labuse@localhost:5432/labuse

# --- Commune pilote (paramétrable ; défaut = Saint-Paul, La Réunion) ---
LABUSE_PILOT_COMMUNE_INSEE=97411
LABUSE_PILOT_COMMUNE_NAME=Saint-Paul

# --- Répertoire des fichiers de configuration (règles & poids) ---
LABUSE_CONFIG_DIR=config

# --- Agent IA (post-cœur ; laisser vide pour utiliser le provider "stub") ---
# LABUSE_AI_PROVIDER=stub            # stub | anthropic
# ANTHROPIC_API_KEY=
# LABUSE_AI_MODEL=claude-sonnet-4-6

# --- Politesse réseau (quotas réels constatés, cf. brief §4) ---
# Altimétrie IGN : 5 req/s · Téléchargement Géoplateforme : 10 req/s · Overpass : ban si martelé
LABUSE_HTTP_TIMEOUT_S=20
