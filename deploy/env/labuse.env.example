# LA BUSE — gabarit d'environnement de PRODUCTION (VPS OVH)
# =============================================================================
# Pose sur le VPS (secrets JAMAIS dans git) :
#   install -o root -g labuse -m 640 deploy/env/labuse.env.example /etc/labuse/labuse.env
#   ${EDITOR:-nano} /etc/labuse/labuse.env      # remplir les valeurs réelles
#   systemctl restart labuse                    # systemd lit EnvironmentFile=/etc/labuse/labuse.env
#
# Toutes les variables de l'app sont préfixées LABUSE_ (pydantic-settings, env_prefix=LABUSE_).
# Seule exception : ANTHROPIC_API_KEY, lue telle quelle par l'assistant IA.
# ⚠️ Ce fichier ne contient QUE des exemples — ne JAMAIS committer une vraie valeur secrète.
#    Sur le VPS, /etc/labuse/labuse.env est HORS du dépôt git, en 640 root:labuse.
# =============================================================================

# --- Base PostGIS (PostgreSQL 16 / PostGIS 3.4) ---------------------------------
# Remplacer par le mot de passe FORT choisi à la création du rôle PostgreSQL.
LABUSE_DATABASE_URL=postgresql+psycopg://labuse:CHANGE_MOI_MOT_DE_PASSE_FORT@localhost:5432/labuse

# --- Mode de déploiement -------------------------------------------------------
# production : auth OBLIGATOIRE (sans mot de passe → routes métier en 503, fail-closed),
#              cookies Secure (servir DERRIÈRE HTTPS), CORS restreint, /docs protégés.
LABUSE_ENV=production

# --- Authentification & sessions (OBLIGATOIRES hors 'local') -------------------
# Mot de passe pilote — en clair OU « sha256:<hexdigest> » (echo -n 'mdp' | sha256sum).
LABUSE_AUTH_PASSWORD=CHANGE_MOI_MOT_DE_PASSE_PILOTE
# Clé de signature des sessions — générer : openssl rand -hex 32
LABUSE_SECRET_KEY=CHANGE_MOI_OPENSSL_RAND_HEX_32
# Durée de session en heures (défaut 12) :
# LABUSE_SESSION_HOURS=12

# --- Domaine public (CORS / origine autorisée hors local) ---------------------
LABUSE_PUBLIC_URL=https://app.labuse.immo

# --- Assistant IA « Expliquer cette parcelle » --------------------------------
# Laisser ANTHROPIC_API_KEY VIDE = mode « synthèse règles » (déterministe, sans réseau,
# déjà premium en démo). Renseigner la clé Anthropic = active le bouton « Enrichir avec l'IA ».
# La clé est lue à l'exécution ; jamais commitée, jamais renvoyée par l'API.
ANTHROPIC_API_KEY=
# Modèle de l'assistant de fiche (défaut claude-sonnet-4-6) :
LABUSE_ASSISTANT_MODEL=claude-sonnet-4-6

# --- Agent IA structuré (src/labuse/ai, optionnel — séparé de l'assistant ci-dessus) ---
# Laisser 'stub' (déterministe, aucun appel réseau) sauf besoin explicite de l'agent LLM.
# LABUSE_AI_PROVIDER=stub            # stub | anthropic
# LABUSE_AI_MODEL=claude-sonnet-4-6

# --- Commune pilote (défaut = Saint-Paul, La Réunion) -------------------------
LABUSE_PILOT_COMMUNE_INSEE=97415
LABUSE_PILOT_COMMUNE_NAME=Saint-Paul

# --- Divers -------------------------------------------------------------------
# Répertoire des règles/poids YAML (laisser 'config') :
# LABUSE_CONFIG_DIR=config
# Politesse réseau (timeout des appels externes, secondes) :
LABUSE_HTTP_TIMEOUT_S=20
# Enrichissement live (RGE ALTI, prescriptions GPU). 1 = actif ; 0 = désactivé (démo offline) :
# LABUSE_ENRICH_LIVE=1

# --- Utilisé UNIQUEMENT par les scripts de déploiement (deploy/scripts/*) ------
# (facultatif : défauts localhost/labuse/5432 + ~/.pgpass pour le mot de passe)
# LABUSE_DB_NAME=labuse
# LABUSE_DB_USER=labuse
# LABUSE_DB_HOST=localhost
# LABUSE_DB_PORT=5432
# LABUSE_BACKUP_DIR=/var/backups/labuse
# LABUSE_BACKUP_KEEP=7
# LABUSE_BASE_URL=http://127.0.0.1:8000
